@charset "UTF-8";#menu{overflow:visible!important;white-space:normal}.header-nav{overflow:visible}.header{overflow:visible}#menu li.has-submenu{position:relative}#menu li.has-submenu>a{position:relative}#menu li.has-submenu>a::after{content:'';position:absolute;bottom:-3px;left:0;right:0;height:2px;background:var(--primary);border-radius:2px;transform:scaleX(0);transform-origin:center;transition:transform .2s ease}#menu li.has-submenu:hover>a::after{transform:scaleX(1)}#menu li.has-submenu>.submenu{display:block;position:absolute;top:calc(100% + 10px);left:50%;transform:translateX(-50%)translateY(-6px);background:var(--theme);border-radius:10px;padding:6px;min-width:0;z-index:200;list-style:none;margin:0;box-shadow:0 8px 24px rgba(0,0,0,.12),0 2px 8px rgba(0,0,0,6%);opacity:0;pointer-events:none;transition:opacity .2s ease,transform .2s ease}#menu li.has-submenu>.submenu::before{content:'';position:absolute;top:-10px;left:0;right:0;height:10px}#menu li.has-submenu:hover>.submenu{opacity:1;pointer-events:auto;transform:translateX(-50%)translateY(0)}#menu li.has-submenu>.submenu li{margin:0}#menu li.has-submenu>.submenu li a{display:block;padding:7px 16px;white-space:nowrap;font-size:13px;font-weight:500;color:var(--primary);border-radius:6px;transition:background .15s ease,color .15s ease;text-decoration:none}#menu li.has-submenu>.submenu li a:hover{background:var(--tertiary)}.hamburger{display:none;flex-direction:column;justify-content:space-between;width:24px;height:18px;background:0 0;border:none;cursor:pointer;padding:0;z-index:201;order:3}.hamburger span{display:block;width:100%;height:2px;background:var(--primary);border-radius:2px;transition:transform .3s ease,opacity .3s ease}.hamburger[aria-expanded=true] span:nth-child(1){transform:translateY(8px)rotate(45deg)}.hamburger[aria-expanded=true] span:nth-child(2){opacity:0}.hamburger[aria-expanded=true] span:nth-child(3){transform:translateY(-8px)rotate(-45deg)}@media(max-width:768px){.header-nav{flex-wrap:wrap;position:relative}.hamburger{display:flex}#menu{display:none!important;flex-direction:column;position:absolute;top:100%;left:0;right:0;background:var(--theme);border-top:1px solid var(--border);padding:8px 0;margin:0;width:100%;z-index:199;box-shadow:0 8px 20px rgba(0,0,0,.1);white-space:normal}#menu.menu-open{display:flex!important}#menu li{width:100%;padding:0;margin:0!important}#menu li a{display:block;padding:10px 20px;font-size:15px}#menu li.has-submenu>.submenu{display:block!important;position:static;border:none;box-shadow:none;padding:0;background:0 0;min-width:unset;opacity:1;pointer-events:auto;transform:none;transition:none}#menu li.has-submenu>.submenu::before{display:none}#menu li.has-submenu>.submenu li a{padding:8px 20px 8px 36px;font-size:14px;color:var(--secondary)}#menu li.has-submenu>a::after{display:none}}.first-entry{position:relative;margin-bottom:var(--gap);padding:var(--gap);background:var(--entry);border-radius:var(--radius);transition:transform .1s;border:1px solid var(--border)}.home-recent-posts{margin-top:2em}.home-recent-posts h2{margin-bottom:var(--gap)}.blog-categories{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:calc(var(--gap) * 1.5);margin-top:var(--gap);align-items:start}.blog-category{border:1px solid var(--border);border-radius:var(--radius);background:var(--entry);overflow:hidden}.blog-category .category-header{padding:var(--gap)var(--gap).5em;border-bottom:1px solid var(--border)}.blog-category .category-title{margin:0 0 .25em;font-size:1.25em}.blog-category .category-title a{color:var(--primary);text-decoration:none}.blog-category .category-title a:hover{text-decoration:underline}.blog-category .category-description{color:var(--secondary);font-size:.85em;margin:0}.blog-category .category-articles{display:flex;flex-direction:column;gap:0;margin:calc(var(--gap) * .75);overflow:hidden}.blog-category .category-articles .post-entry{position:relative;padding:.65em .9em;border-bottom:1px solid var(--border);transition:background .15s ease;background-color:color-mix(in srgb,var(--primary) 5%,transparent)}.blog-category .category-articles .post-entry:last-child{border-bottom:none}.blog-category .category-articles .post-entry:hover{background:var(--tertiary)}.blog-category .category-articles .post-entry .entry-header h3{margin:0;font-size:.92em;font-weight:600}.blog-category .category-articles .post-entry .entry-footer{font-size:.75em;color:var(--secondary);margin:.15em 0 .3em}.blog-category .category-articles .post-entry .entry-content p{margin:0;font-size:.85em;color:var(--secondary);display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}.blog-category .category-footer{padding:.5em var(--gap)var(--gap)}.blog-category .see-all-link{display:inline-block;font-size:.85em;font-weight:600;color:var(--primary);text-decoration:none}.blog-category .see-all-link:hover{text-decoration:underline}.blog-category .no-articles{color:var(--secondary);font-style:italic;font-size:.9em;padding:var(--gap)}.post-single .post-header{border-bottom:1px solid var(--border);padding-bottom:var(--content-gap);margin-bottom:var(--content-gap)}.post-title{font-size:clamp(1.6rem,4vw,2.2rem);line-height:1.2;letter-spacing:-.02em}.post-description{font-size:1rem;color:var(--secondary);line-height:1.65;margin-top:.6em}.post-meta{margin-top:.85rem;font-size:.82rem;color:var(--secondary);display:flex;flex-wrap:wrap;align-items:center;gap:.1rem 0}.post-content.md-content{font-size:1rem;line-height:1.78}.post-content.md-content h2{position:relative;padding-left:.9rem;margin-top:2.5rem}.post-content.md-content h2::before{content:'';position:absolute;left:0;top:.15em;bottom:.1em;width:3px;background:var(--primary);border-radius:3px}.post-content.md-content h3{margin-top:1.8rem;padding-bottom:.3em;border-bottom:1px solid var(--border)}.post-content.md-content blockquote{background:color-mix(in srgb,var(--primary) 5%,transparent);border-inline-start:3px solid var(--primary);border-radius:0 var(--radius)var(--radius)0;padding:.8rem 1.25rem;margin:1.25rem 0}.post-content.md-content blockquote p{margin-bottom:0;font-style:italic;color:var(--secondary)}.post-content.md-content table{width:100%;border-collapse:separate;border-spacing:0;border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;font-size:.88rem}.post-content.md-content table th{background:color-mix(in srgb,var(--primary) 7%,transparent);font-weight:600;padding:10px 14px;border-bottom:2px solid var(--border);text-align:left}.post-content.md-content table td{padding:8px 14px;border-bottom:1px solid var(--border);vertical-align:top;min-width:unset}.post-content.md-content table tr:last-child td{border-bottom:none}.post-content.md-content table tr:nth-child(even) td{background:color-mix(in srgb,var(--primary) 3%,transparent)}.post-content.md-content img{display:block;margin:1.5rem auto;max-width:100%;border-radius:var(--radius);box-shadow:0 2px 14px rgba(0,0,0,8%)}.post-content.md-content a{text-decoration-color:color-mix(in srgb,var(--primary) 35%,transparent);transition:text-decoration-color .15s ease}.post-content.md-content a:hover{text-decoration-color:var(--primary)}.post-content.md-content hr{border:none;height:1px;background:var(--border);margin:2rem 0}.post-footer{margin-top:calc(var(--gap) * 2);padding-top:var(--gap);border-top:1px solid var(--border)}.post-tags{gap:8px}.post-tags::before{content:'🏷️';font-size:.9rem;align-self:center;margin-right:2px}.post-tags a{font-size:.78rem;padding:.2rem .8rem;line-height:1.8;border-radius:999px;background:var(--code-bg);border:1px solid var(--border);color:var(--secondary);font-weight:500;transition:background .15s ease,color .15s ease,border-color .15s ease}.post-tags a:hover{background:var(--primary);color:var(--theme);border-color:var(--primary)}.paginav{margin-top:var(--gap);display:grid;grid-template-columns:1fr 1fr;gap:var(--gap);border:none;background:0 0;line-height:1.4}.paginav a{width:100%;display:flex;flex-direction:column;gap:.4rem;padding:var(--gap);background:var(--entry);border:1px solid var(--border);border-radius:var(--radius);transition:border-color .15s ease,box-shadow .15s ease}.paginav a:hover{border-color:var(--primary);box-shadow:0 2px 10px rgba(0,0,0,7%)}.paginav .title{font-size:.7rem;text-transform:uppercase;letter-spacing:.07em;color:var(--secondary)}.paginav .prev .title::before{content:'← '}.paginav .next .title::after{content:' →'}.paginav span:not(.title){font-size:.9rem;font-weight:600;color:var(--primary)}.paginav .next{text-align:right;margin-inline-start:0}@media(max-width:600px){.paginav{grid-template-columns:1fr}.post-content.md-content h2{font-size:1.35rem}}